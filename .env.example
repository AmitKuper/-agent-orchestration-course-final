# Database — use aiosqlite for local dev, asyncpg for production
DATABASE_URL=sqlite+aiosqlite:///./cop_thief.db

# Secret key for signing JWT tokens — replace with a long random string
SECRET_KEY=change-me-in-production

# Name displayed publicly as the local server identity
SERVER_NAME=cop-thief-server

# CORS origins allowed to call the REST API (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# LLM API key — used only by the Gatekeeper, never called directly from agents
ANTHROPIC_API_KEY=

# Email delivery — leave empty to disable email
EMAIL_RECIPIENT=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
